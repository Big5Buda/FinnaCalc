# ── Stock market data (Investing tab) ──
# Free key: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ── Sector browse batch quotes (Investing "Browse by Industry", /api/market-overview) ──
# Free account, no funding needed (a paper-trading account is enough):
# https://alpaca.markets/ → Generate API keys. Powers up to 15 stocks per
# sector in one batch call; falls back to FMP (paid plans only for its
# batch-quote endpoint) then Finnhub (6/sector) if unset.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# ── Price-history chart candles (/api/candles) ──
# Finnhub candles are premium and Yahoo now throttles servers, so the native
# stock chart uses Twelve Data. Free key (800 req/day): https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=

# ── Stock screener (/api/screener) ──
# Finnhub has no free screener, so /api/screener uses Financial Modeling Prep's
# /stock-screener (whole-market, server-side filters). Free key (~250 req/day):
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# ── Chatbot (FinnaBot, Google Gemini) ──
# Free key: https://aistudio.google.com/app/apikey  (looks like "AIza...")
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Portfolio import (Plaid Investments) ──
# Keys: https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
# "sandbox" (test data, default) or "production"
PLAID_ENV=sandbox

# ── Authentication (Supabase) ──
# Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (Settings → API → service_role). SERVER-ONLY — never expose
# to the client. Used by /api/account/delete to delete a user's account and by
# the SnapTrade session store (lib/snaptrade-session.ts), which keeps brokerage
# credentials server-side in the snaptrade_users table — create it by running
# supabase/snaptrade_users.sql once in the Supabase SQL editor.
SUPABASE_SERVICE_ROLE_KEY=

# ── Waitlist confirmation email (Resend) ──
# Free key: https://resend.com/api-keys. Verify your sending domain in Resend
# (add the SPF/DKIM DNS records it shows to your DNS host). Both vars must be set
# or the confirmation email is silently skipped (signups still save).
RESEND_API_KEY=
# From address; the domain must be verified in Resend. Display name + address:
WAITLIST_FROM_EMAIL="FinnaCalc <finnacalc@felipejmiranda.com>"

# ── Brokerage connections (SnapTrade) ──
# Free dev keys: https://dashboard.snaptrade.com
# Also whitelist your redirect URL (e.g. http://localhost:3000/investing and
# https://www.finnacalc.com/investing) in the SnapTrade dashboard.
# Webhooks: point the SnapTrade Dashboard's Webhooks tab at
# https://www.finnacalc.com/api/snaptrade/webhook — authenticity is verified
# with SNAPTRADE_CONSUMER_KEY (HMAC-SHA256), so no separate webhook secret.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
